<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fines — RV University Library</title>

  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet">

  <%- include('_layout') %>
</head>

<body>

  <%- include('_sidebar', {active:'fines'}) %>

    <div class="main">

      <header class="topbar">

        <span class="topbar-title">
          Fines
        </span>

        <div class="topbar-right">
          <div class="admin-badge">
            <span class="admin-dot"></span>
            <span>Admin</span>
          </div>
        </div>

      </header>

      <div class="page-body">

        <% const totalFines=fines.reduce((sum, f)=>
          sum + Number(f.amount), 0);

          const unpaidFines =
          fines
          .filter(f => f.paid_status !== 'Paid')
          .reduce((sum, f) =>
          sum + Number(f.amount), 0);

          const paidFines =
          fines
          .filter(f => f.paid_status === 'Paid')
          .reduce((sum, f) =>
          sum + Number(f.amount), 0);
          %>

          <% if(success && success.length> 0){ %>

            <div style="
            background:#dcfce7;
            color:#166534;
            padding:14px 18px;
            border-radius:12px;
            margin-bottom:20px;
            border:1px solid #bbf7d0;
            font-weight:600;
          ">
              <%= success %>
            </div>

            <% } %>

              <!-- Summary Cards -->

              <div style="
          display:grid;
          grid-template-columns:repeat(3,1fr);
          gap:16px;
          margin-bottom:24px;
        ">

                <div style="
            background:white;
            border:1px solid var(--rv-gray-100);
            border-radius:var(--radius);
            padding:20px;
            box-shadow:var(--shadow);
          ">

                  <div style="
              font-size:11px;
              font-weight:700;
              letter-spacing:1px;
              text-transform:uppercase;
              color:var(--rv-gray-400);
              margin-bottom:8px;
            ">
                    Total Fines
                  </div>

                  <div style="
              font-family:'Playfair Display',serif;
              font-size:32px;
              color:var(--rv-gray-800);
            ">
                    ₹<%= totalFines %>
                  </div>

                </div>

                <div style="
            background:white;
            border:1px solid var(--rv-gray-100);
            border-radius:var(--radius);
            padding:20px;
            box-shadow:var(--shadow);
          ">

                  <div style="
              font-size:11px;
              font-weight:700;
              letter-spacing:1px;
              text-transform:uppercase;
              color:var(--rv-gray-400);
              margin-bottom:8px;
            ">
                    Unpaid
                  </div>

                  <div style="
              font-family:'Playfair Display',serif;
              font-size:32px;
              color:#dc2626;
            ">
                    ₹<%= unpaidFines %>
                  </div>

                </div>

                <div style="
            background:white;
            border:1px solid var(--rv-gray-100);
            border-radius:var(--radius);
            padding:20px;
            box-shadow:var(--shadow);
          ">

                  <div style="
              font-size:11px;
              font-weight:700;
              letter-spacing:1px;
              text-transform:uppercase;
              color:var(--rv-gray-400);
              margin-bottom:8px;
            ">
                    Collected
                  </div>

                  <div style="
              font-family:'Playfair Display',serif;
              font-size:32px;
              color:#16a34a;
            ">
                    ₹<%= paidFines %>
                  </div>

                </div>

              </div>

              <!-- Main Table -->

              <div class="card">

                <div class="card-header">

                  <h2>
                    Fine Records

                    <span style="
                font-weight:400;
                color:var(--rv-gray-400);
                font-size:13px;
                margin-left:8px;
              ">
                      <%= fines.length %> entries
                    </span>

                  </h2>

                </div>

                <div class="table-wrap">

                  <table>

                    <thead>

                      <tr>

                        <th>#</th>

                        <th>Student</th>

                        <th>USN</th>

                        <th>Book</th>

                        <th>Amount</th>

                        <th>Status</th>

                        <th>Action</th>

                      </tr>

                    </thead>

                    <tbody>

                      <% fines.forEach((fine, i)=> { %>

                        <tr>

                          <td class="td-muted">
                            <%= i + 1 %>
                          </td>

                          <td style="font-weight:600;">
                            <%= fine.student_name %>
                          </td>

                          <td>
                            <code style="
                      font-size:12px;
                      background:var(--rv-gray-100);
                      padding:4px 8px;
                      border-radius:5px;
                    ">
                    <%= fine.usn %>
                  </code>
                          </td>

                          <td>
                            <%= fine.book_title %>
                          </td>

                          <td style="
                    font-weight:700;
                    font-size:15px;
                    color:<%= fine.paid_status === 'Paid'
                      ? '#16a34a'
                      : '#dc2626' %>;
                  ">
                            ₹<%= fine.amount %>
                          </td>

                          <td>

                            <% if(fine.paid_status==='Paid' ){ %>

                              <span class="badge badge-success">

                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                  stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                  <polyline points="20 6 9 17 4 12" />
                                </svg>

                                Paid

                              </span>

                              <% } else { %>

                                <span class="badge badge-danger">
                                  Unpaid
                                </span>

                                <% } %>

                          </td>

                          <td>

                            <% if(fine.paid_status !=='Paid' ){ %>

                              <a href="/fines/pay/<%= fine.id %>" style="
                        background:#16a34a;
                        color:white;
                        padding:8px 14px;
                        border-radius:8px;
                        text-decoration:none;
                        font-size:13px;
                        font-weight:600;
                        display:inline-block;
                      ">
                                Mark As Paid
                              </a>

                              <% } else { %>

                                <button disabled style="
                        background:#d1d5db;
                        color:#6b7280;
                        padding:8px 14px;
                        border:none;
                        border-radius:8px;
                        font-size:13px;
                        font-weight:600;
                      ">
                                  Paid
                                </button>

                                <% } %>

                          </td>

                        </tr>

                        <% }) %>

                          <% if(fines.length===0){ %>

                            <tr>

                              <td colspan="7" style="
                    text-align:center;
                    padding:48px;
                    color:var(--rv-gray-400);
                  ">
                                No fines recorded.
                              </td>

                            </tr>

                            <% } %>

                    </tbody>

                  </table>

                </div>

              </div>

      </div>

    </div>

</body>

</html>