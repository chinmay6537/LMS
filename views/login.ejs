<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — RV University Library</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet">
  <style>
    :root {
      --rv-maroon: #7B1C1C;
      --rv-maroon-dark: #5a1212;
      --rv-maroon-light: #9e2a2a;
      --rv-gold: #C9A84C;
      --rv-gold-light: #e8c97a;
      --rv-cream: #FDF8F0;
      --rv-gray-100: #f0ebe2;
      --rv-gray-200: #e2d9cc;
      --rv-gray-400: #9e9080;
      --rv-gray-600: #5c5248;
      --rv-gray-800: #2d2620;
    }

    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--rv-cream);
      min-height: 100vh;
      display: flex;
    }

    .login-left {
      width: 460px;
      background: var(--rv-maroon);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 52px 48px;
      position: relative;
      overflow: hidden;
    }

    .login-left::before {
      content: '';
      position: absolute;
      top: -80px;
      right: -80px;
      width: 300px;
      height: 300px;
      background: rgba(201, 168, 76, 0.1);
      border-radius: 50%;
    }

    .login-left::after {
      content: '';
      position: absolute;
      bottom: -60px;
      left: -60px;
      width: 220px;
      height: 220px;
      background: rgba(201, 168, 76, 0.06);
      border-radius: 50%;
    }

    .brand {
      position: relative;
      z-index: 1;
    }

    .brand-tag {
      display: inline-block;
      background: var(--rv-gold);
      color: var(--rv-maroon-dark);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 4px;
      margin-bottom: 20px;
    }

    .brand h1 {
      font-family: 'Playfair Display', serif;
      font-size: 36px;
      color: white;
      line-height: 1.25;
      font-weight: 700;
      margin-bottom: 14px;
    }

    .brand p {
      color: rgba(255, 255, 255, 0.5);
      font-size: 14px;
      line-height: 1.7;
      max-width: 300px;
    }

    .left-footer {
      position: relative;
      z-index: 1;
    }

    .left-footer p {
      color: rgba(255, 255, 255, 0.25);
      font-size: 12px;
    }

    .login-right {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px;
    }

    .login-card {
      width: 100%;
      max-width: 380px;
      animation: slideIn 0.4s ease both;
    }

    .login-card h2 {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      color: var(--rv-gray-800);
      margin-bottom: 6px;
    }

    .login-card .subtitle {
      color: var(--rv-gray-400);
      font-size: 14px;
      margin-bottom: 32px;
    }

    .gold-bar {
      width: 40px;
      height: 3px;
      background: var(--rv-gold);
      border-radius: 2px;
      margin: 16px 0 28px;
    }

    .form-group {
      margin-bottom: 18px;
    }

    .form-label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      color: var(--rv-gray-600);
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 7px;
    }

    .form-control {
      width: 100%;
      padding: 12px 16px;
      border: 1.5px solid var(--rv-gray-200);
      border-radius: 10px;
      font-size: 14px;
      font-family: 'DM Sans', sans-serif;
      color: var(--rv-gray-800);
      background: white;
      outline: none;
      transition: all 0.15s;
    }

    .form-control:focus {
      border-color: var(--rv-maroon);
      box-shadow: 0 0 0 3px rgba(123, 28, 28, 0.1);
    }

    .btn-login {
      width: 100%;
      padding: 13px;
      background: var(--rv-maroon);
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 600;
      font-family: 'DM Sans', sans-serif;
      cursor: pointer;
      letter-spacing: 0.3px;
      transition: all 0.15s;
      margin-top: 6px;
    }

    .btn-login:hover {
      background: var(--rv-maroon-light);
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(123, 28, 28, 0.3);
    }

    .note {
      margin-top: 24px;
      text-align: center;
      font-size: 12px;
      color: var(--rv-gray-400);
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(20px)
      }

      to {
        opacity: 1;
        transform: translateX(0)
      }
    }
  </style>
</head>

<body>
  <div class="login-left">
    <div class="brand">
      <span class="brand-tag">RV University</span>
      <h1>Library<br>Management<br>System</h1><br>

      <p>Atharva SM</p>
      <p>Chandra Sriyanth</p>
      <p>Chinmay S</p>
    </div>
    <div class="left-footer">
      <p>© 2026 RV University, Bengaluru</p>
    </div>
  </div>

  <div class="login-right">
    <div class="login-card">
      <h2>Welcome back</h2>
      <p class="subtitle">Sign in with your admin credentials</p>
      <div class="gold-bar"></div>

      <form action="/login" method="POST">
        <div class="form-group">
          <label class="form-label">Username</label>
          <input class="form-control" type="text" name="username" placeholder="Enter your username" required autofocus>
        </div>
        <div class="form-group">
          <label class="form-label">Password</label>
          <input class="form-control" type="password" name="password" placeholder="Enter your password" required>
        </div>
        <button class="btn-login" type="submit">Sign In →</button>
      </form>

      <p class="note">Admin access only</p>
    </div>
  </div>
</body>

</html>