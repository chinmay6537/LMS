<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Book — RV University Library</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <%- include('_layout') %>
</head>
<body>
  <%- include('_sidebar', {active:'books'}) %>

  <div class="main">
    <header class="topbar">
      <span class="topbar-title">Edit Book</span>
      <div class="topbar-right">
        <div class="admin-badge"><span class="admin-dot"></span><span>Admin</span></div>
      </div>
    </header>

    <div class="page-body">
      <a href="/books" class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Back to Books
      </a>

      <div style="max-width:520px;">
        <div class="card">
          <div class="card-header">
            <h2>Edit Book Details</h2>
            <span style="font-size:12px;color:var(--rv-gray-400);">ID #<%= book.id %></span>
          </div>
          <div class="card-body">
            <form action="/books/update/<%= book.id %>" method="POST">
              <div class="form-group">
                <label class="form-label">Title</label>
                <input class="form-control" type="text" name="title" value="<%= book.title %>" required>
              </div>
              <div class="form-group">
                <label class="form-label">Author</label>
                <input class="form-control" type="text" name="author" value="<%= book.author %>" required>
              </div>
              <div class="form-group">
                <label class="form-label">Category</label>
                <input class="form-control" type="text" name="category" value="<%= book.category %>" required>
              </div>
              <div class="form-group">
                <label class="form-label">Quantity</label>
                <input class="form-control" type="number" name="quantity" value="<%= book.quantity %>" min="1" required>
              </div>

              <div style="display:flex;gap:10px;margin-top:20px;">
                <button class="btn btn-primary" type="submit" style="flex:1;justify-content:center;">Save Changes</button>
                <a href="/books" class="btn btn-ghost">Cancel</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
