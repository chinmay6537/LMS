<!-- RV University LMS - Shared CSS & Sidebar -->
<!-- Include this style block in every view -->
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap');

  :root {
    --rv-maroon: #7B1C1C;
    --rv-maroon-dark: #5a1212;
    --rv-maroon-light: #9e2a2a;
    --rv-gold: #C9A84C;
    --rv-gold-light: #e8c97a;
    --rv-cream: #FDF8F0;
    --rv-white: #ffffff;
    --rv-gray-50: #f9f6f1;
    --rv-gray-100: #f0ebe2;
    --rv-gray-200: #e2d9cc;
    --rv-gray-400: #9e9080;
    --rv-gray-600: #5c5248;
    --rv-gray-800: #2d2620;
    --sidebar-w: 260px;
    --radius: 12px;
    --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 4px 16px rgba(0,0,0,0.08);
    --shadow-lg: 0 8px 32px rgba(0,0,0,0.12);
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--rv-gray-50);
    color: var(--rv-gray-800);
    display: flex;
    min-height: 100vh;
  }

  /* ── SIDEBAR ── */
  .sidebar {
    width: var(--sidebar-w);
    height: 100vh;
    background: var(--rv-maroon);
    position: fixed;
    top: 0; left: 0;
    display: flex;
    flex-direction: column;
    z-index: 100;
    overflow: hidden;
  }

  .sidebar::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 200px; height: 200px;
    background: rgba(201,168,76,0.12);
    border-radius: 50%;
    pointer-events: none;
  }

  .sidebar-brand {
    padding: 28px 24px 20px;
    border-bottom: 1px solid rgba(201,168,76,0.25);
  }

  .sidebar-brand .brand-badge {
    display: inline-block;
    background: var(--rv-gold);
    color: var(--rv-maroon-dark);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
    margin-bottom: 10px;
  }

  .sidebar-brand h1 {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    color: var(--rv-white);
    line-height: 1.3;
    font-weight: 700;
  }

  .sidebar-brand p {
    font-size: 11px;
    color: rgba(255,255,255,0.5);
    margin-top: 4px;
    letter-spacing: 0.5px;
  }

  .sidebar-nav {
    flex: 1;
    padding: 16px 12px;
    overflow-y: auto;
  }

  .nav-section-label {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    padding: 0 12px;
    margin: 16px 0 6px;
  }

  .sidebar-nav a {
    display: flex;
    align-items: center;
    gap: 12px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 400;
    transition: all 0.18s ease;
    margin-bottom: 2px;
  }

  .sidebar-nav a:hover, .sidebar-nav a.active {
    background: rgba(201,168,76,0.15);
    color: var(--rv-gold-light);
  }

  .sidebar-nav a.active {
    background: rgba(201,168,76,0.2);
    color: var(--rv-gold);
    font-weight: 500;
  }

  .sidebar-nav a svg { flex-shrink: 0; opacity: 0.85; }

  .sidebar-footer {
    padding: 16px 12px;
    border-top: 1px solid rgba(201,168,76,0.2);
  }

  .sidebar-footer a {
    display: flex;
    align-items: center;
    gap: 12px;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 14px;
    transition: all 0.18s;
  }

  .sidebar-footer a:hover { color: #ff8a8a; background: rgba(255,100,100,0.1); }

  /* ── MAIN CONTENT ── */
  .main {
    margin-left: var(--sidebar-w);
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .topbar {
    background: var(--rv-white);
    border-bottom: 1px solid var(--rv-gray-100);
    padding: 0 32px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .topbar-title {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    color: var(--rv-maroon);
    font-weight: 600;
  }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .admin-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--rv-gray-50);
    border: 1px solid var(--rv-gray-200);
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 13px;
    color: var(--rv-gray-600);
  }

  .admin-dot {
    width: 8px; height: 8px;
    background: #22c55e;
    border-radius: 50%;
  }

  .page-body {
    padding: 32px;
    flex: 1;
  }

  /* ── CARDS ── */
  .card {
    background: var(--rv-white);
    border: 1px solid var(--rv-gray-100);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .card-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--rv-gray-100);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .card-header h2 {
    font-size: 15px;
    font-weight: 600;
    color: var(--rv-gray-800);
  }

  .card-body { padding: 24px; }

  /* ── STAT CARDS ── */
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 28px;
  }

  .stat-card {
    background: var(--rv-white);
    border: 1px solid var(--rv-gray-100);
    border-radius: var(--radius);
    padding: 24px;
    box-shadow: var(--shadow);
    position: relative;
    overflow: hidden;
  }

  .stat-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
  }

  .stat-card.maroon::after { background: var(--rv-maroon); }
  .stat-card.gold::after { background: var(--rv-gold); }
  .stat-card.green::after { background: #22c55e; }
  .stat-card.red::after { background: #ef4444; }

  .stat-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--rv-gray-400);
    margin-bottom: 10px;
  }

  .stat-value {
    font-family: 'Playfair Display', serif;
    font-size: 42px;
    font-weight: 700;
    line-height: 1;
  }

  .stat-card.maroon .stat-value { color: var(--rv-maroon); }
  .stat-card.gold .stat-value { color: var(--rv-gold); }
  .stat-card.green .stat-value { color: #16a34a; }
  .stat-card.red .stat-value { color: #dc2626; }

  .stat-icon {
    position: absolute;
    top: 20px; right: 20px;
    opacity: 0.08;
  }

  /* ── TABLES ── */
  .table-wrap { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13.5px;
  }

  thead th {
    background: var(--rv-gray-50);
    color: var(--rv-gray-600);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--rv-gray-200);
    white-space: nowrap;
  }

  tbody tr {
    border-bottom: 1px solid var(--rv-gray-100);
    transition: background 0.12s;
  }

  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: var(--rv-cream); }

  tbody td {
    padding: 13px 16px;
    color: var(--rv-gray-800);
    vertical-align: middle;
  }

  .td-muted { color: var(--rv-gray-400); font-size: 12px; }

  /* ── BUTTONS ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .btn-primary {
    background: var(--rv-maroon);
    color: white;
  }
  .btn-primary:hover { background: var(--rv-maroon-light); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(123,28,28,0.3); }

  .btn-gold {
    background: var(--rv-gold);
    color: var(--rv-maroon-dark);
  }
  .btn-gold:hover { background: var(--rv-gold-light); }

  .btn-ghost {
    background: transparent;
    color: var(--rv-gray-600);
    border: 1px solid var(--rv-gray-200);
  }
  .btn-ghost:hover { background: var(--rv-gray-100); }

  .btn-danger {
    background: #fee2e2;
    color: #991b1b;
  }
  .btn-danger:hover { background: #fecaca; }

  .btn-success {
    background: #dcfce7;
    color: #166534;
  }
  .btn-success:hover { background: #bbf7d0; }

  .btn-sm { padding: 5px 11px; font-size: 12px; border-radius: 6px; }

  /* ── FORMS ── */
  .form-group { margin-bottom: 18px; }

  .form-label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--rv-gray-600);
    letter-spacing: 0.4px;
    margin-bottom: 6px;
    text-transform: uppercase;
  }

  .form-control {
    width: 100%;
    padding: 10px 14px;
    border: 1.5px solid var(--rv-gray-200);
    border-radius: 8px;
    font-size: 14px;
    font-family: 'DM Sans', sans-serif;
    color: var(--rv-gray-800);
    background: var(--rv-white);
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
    appearance: none;
  }

  .form-control:focus {
    border-color: var(--rv-maroon);
    box-shadow: 0 0 0 3px rgba(123,28,28,0.1);
  }

  .form-row {
    display: grid;
    gap: 16px;
  }

  .form-row.cols-2 { grid-template-columns: 1fr 1fr; }
  .form-row.cols-4 { grid-template-columns: 1fr 1fr 1fr 1fr; }
  .form-row.cols-5 { grid-template-columns: 1fr 1fr 1fr 1fr auto; }

  /* ── BADGES ── */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 9px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.3px;
  }

  .badge-success { background: #dcfce7; color: #166534; }
  .badge-warning { background: #fef9c3; color: #854d0e; }
  .badge-danger { background: #fee2e2; color: #991b1b; }
  .badge-gray { background: var(--rv-gray-100); color: var(--rv-gray-600); }

  /* ── ALERT ── */
  .alert {
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 13.5px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .alert-success {
    background: #dcfce7;
    color: #166534;
    border: 1px solid #bbf7d0;
  }

  /* ── BACK LINK ── */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--rv-maroon);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 20px;
    opacity: 0.8;
    transition: opacity 0.15s;
  }

  .back-link:hover { opacity: 1; }

  /* ── SEARCH BAR ── */
  .search-bar {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .search-wrap {
    position: relative;
    flex: 1;
  }

  .search-wrap svg {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--rv-gray-400);
    pointer-events: none;
  }

  .search-wrap .form-control { padding-left: 38px; }

  /* ── ADD FORM PANEL ── */
  .add-panel {
    background: var(--rv-cream);
    border: 1px solid var(--rv-gray-200);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 24px;
  }

  .add-panel-title {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--rv-maroon);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Divider */
  .section-divider {
    border: none;
    border-top: 1px solid var(--rv-gray-100);
    margin: 0;
  }

  /* Animations */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .page-body { animation: fadeUp 0.3s ease both; }
</style>
